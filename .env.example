# =============================================================================
# Vite Environment Variables — E-Commerce Frontend
# =============================================================================
# Copy this file to .env and adjust values for your local setup.
#
# VITE_API_BASE_URL
#   Development:  Leave empty ("") — Vite proxy forwards /api/* requests.
#   Production:   Set to your deployed backend URL.
#
# Examples:
#   VITE_API_BASE_URL=https://api.example.com
# =============================================================================

VITE_API_BASE_URL=
